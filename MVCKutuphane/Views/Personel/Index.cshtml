@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/Layout.cshtml";
}




<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<div class="container py-5">

    <!-- Başlık -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>
            <h2 class="fw-bold mb-1">Personel Yönetimi</h2>
            <p class="text-muted mb-0">
                Sistemde kayıtlı personelleri buradan yönetebilirsiniz.
            </p>
        </div>

        <a href="/Personel/PersonelEkle/" class="btn btn-dark rounded-3 px-4 shadow-sm">
            <i class="fas fa-plus me-2"></i> Yeni Personel
        </a>

    </div>

    <!-- Kart -->
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <!-- Table -->
        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th style="width:120px;">#</th>
                        <th>Personel Adı</th>
                        <th class="text-center" style="width:180px;">İşlemler</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td class="fw-semibold text-secondary">
                                #@item.ID
                            </td>

                            <td>
                                <div class="d-flex align-items-center gap-3">

                                    <div class="bg-dark text-white rounded-circle d-flex justify-content-center align-items-center"
                                         style="width:45px; height:45px; font-weight:600;">

                                        @item.PERSONEL.Substring(0, 1).ToUpper()

                                    </div>

                                    <div>
                                        <div class="fw-semibold fs-6">
                                            @item.PERSONEL
                                        </div>

                                        <small class="text-muted">
                                            Kütüphane Personeli
                                        </small>
                                    </div>

                                </div>
                            </td>

                            <td>

                                <div class="d-flex justify-content-center gap-2">

                                    <a href="/Personel/PersonelGetir/@item.ID"
                                       class="btn btn-outline-primary btn-sm rounded-3 px-3">

                                        <i class="fas fa-pen"></i>
                                    </a>

                                    <a href="/Personel/Sil/@item.ID"
                                       class="btn btn-outline-danger btn-sm rounded-3 px-3"
                                       onclick="return confirm('Personeli silmek istediğinize emin misiniz?')">

                                        <i class="fas fa-trash"></i>
                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>