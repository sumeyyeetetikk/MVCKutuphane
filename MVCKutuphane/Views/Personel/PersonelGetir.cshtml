@model MVCKutuphane.Models.Entity.TBLPERSONEL
@{
    ViewBag.Title = "PersonelGetir";
    Layout = "~/Views/Shared/Layout.cshtml";
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- HEADER -->
                <div class="bg-primary text-white p-4">

                    <h3 class="fw-bold mb-1">
                        <i class="fas fa-user-edit me-2"></i>
                        Personel Güncelle
                    </h3>

                    <p class="mb-0 text-light">
                        Personel bilgilerini güncelleyebilirsiniz.
                    </p>

                </div>

                <!-- BODY -->
                <div class="card-body p-5">

                    @using (Html.BeginForm("PersonelGuncelle", "Personel", FormMethod.Post))
                    {

                        @Html.HiddenFor(x => x.ID)

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Personel Adı Soyadı
                            </label>

                            @Html.TextBoxFor(x => x.PERSONEL, new
                            {
                                @class = "form-control form-control-lg rounded-3 shadow-sm",
                                placeholder = "Personel adı giriniz"
                            })

                        </div>

                        <div class="d-flex gap-2">

                            <button class="btn btn-primary px-4 py-2 rounded-3 shadow-sm"
                                    type="submit">

                                <i class="fas fa-save me-2"></i>
                                Güncelle

                            </button>

                            <a href="/Personel/Index/"
                               class="btn btn-outline-secondary px-4 py-2 rounded-3">

                                <i class="fas fa-arrow-left me-2"></i>
                                Geri Dön

                            </a>

                        </div>

                    }

                </div>

            </div>

        </div>

    </div>

</div>