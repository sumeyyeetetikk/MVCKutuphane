@model MVCKutuphane.Models.Entity.TBLKITAP
@{
    ViewBag.Title = "KitapEkle";
    Layout = "~/Views/Shared/Layout.cshtml";
}






<div class="container-fluid">

    <div class="mb-4">

        <h3 class="fw-bold mb-1">Yeni Kitap Ekle</h3>

        <p class="text-muted">
            Kütüphane sistemine yeni kitap ekleyebilirsiniz.
        </p>

    </div>

    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-4">

            @using (Html.BeginForm("KitapEkle", "Kitap", FormMethod.Post))
            {

                <div class="mb-4">

                    <label class="form-label fw-semibold">
                        Kitap Adı
                    </label>

                    @Html.TextBoxFor(x => x.AD, new
                    {
                        @class = "form-control form-control-lg rounded-4",
                        placeholder = "Kitap adını giriniz..."
                    })

                </div>

                <div class="mb-4">

                    <label class="form-label fw-semibold">
                        Kategori
                    </label>

                    @Html.DropDownListFor(x => x.TBLKATEGORI.ID,
                        (List<SelectListItem>)ViewBag.dgr1,
                        "Kategori Seçiniz",
                        new
                        {
                            @class = "form-select form-select-lg rounded-4"
                        })

                </div>

                <div class="mb-4">

                    <label class="form-label fw-semibold">
                        Yazar
                    </label>

                    @Html.DropDownListFor(x => x.TBLYAZAR.ID,
                        (List<SelectListItem>)ViewBag.dgr2,
                        "Yazar Seçiniz",
                        new
                        {
                            @class = "form-select form-select-lg rounded-4"
                        })

                </div>

                <div class="mb-4">

                    <label class="form-label fw-semibold">
                        Yayınevi
                    </label>

                    @Html.TextBoxFor(x => x.YAYIMEVI, new
                    {
                        @class = "form-control form-control-lg rounded-4",
                        placeholder = "Yayınevi giriniz..."
                    })

                </div>

                <div class="mb-4">

                    <label class="form-label fw-semibold">
                        Basım Yılı
                    </label>

                    @Html.TextBoxFor(x => x.BASIMYIL, new
                    {
                        @class = "form-control form-control-lg rounded-4",
                        placeholder = "Basım yılı giriniz..."
                    })

                </div>

                <div class="mb-4">

                    <label class="form-label fw-semibold">
                        Sayfa Sayısı
                    </label>

                    @Html.TextBoxFor(x => x.SAYFA, new
                    {
                        @class = "form-control form-control-lg rounded-4",
                        placeholder = "Sayfa sayısı giriniz..."
                    })

                </div>

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn btn-primary rounded-pill px-4">

                        <i class="fa-solid fa-floppy-disk me-2"></i>
                        Kaydet

                    </button>

                    <a href="/Kitap/Index"
                       class="btn btn-secondary rounded-pill px-4">

                        <i class="fa-solid fa-arrow-left me-2"></i>
                        Geri Dön

                    </a>

                </div>
            }

        </div>

    </div>

</div>