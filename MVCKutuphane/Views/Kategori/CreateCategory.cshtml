@model MVCKutuphane.Models.Entity.TBLKATEGORI
@{
    ViewBag.Title = "CreateCategory";
    Layout = "~/Views/Shared/Layout.cshtml";
}



<div class="container-fluid">

    <div class="mb-4">
        <h3 class="fw-bold mb-1">Yeni Kategori Ekle</h3>
        <p class="text-muted">Kütüphane sistemine yeni kategori ekleyebilirsiniz.</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            @using (Html.BeginForm("YeniKategori", "Kategori", FormMethod.Post))
            {
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Kategori Adı
                    </label>

                    @Html.TextBoxFor(x => x.AD, new
                    {
                        @class = "form-control form-control-lg rounded-4",
                        placeholder = "Kategori adını giriniz..."
                    })
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary rounded-pill px-4">
                        <i class="fa-solid fa-floppy-disk me-2"></i>
                        Kaydet
                    </button>

                    <a href="/Kategori/Index" class="btn btn-secondary rounded-pill px-4">
                        <i class="fa-solid fa-arrow-left me-2"></i>
                        Geri Dön
                    </a>
                </div>
            }

        </div>
    </div>

</div>