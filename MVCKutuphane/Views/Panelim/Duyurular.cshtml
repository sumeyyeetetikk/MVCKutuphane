@using MVCKutuphane.Models.Entity
@{
    ViewBag.Title = "Duyurular";
    Layout = "~/Views/Shared/_LayoutPanel.cshtml";
}




<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<div class="container py-5" style="max-width: 900px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">

    <div class="text-center mb-5">
        <i class="fas fa-bullhorn fa-3x text-primary mb-3"></i>
        <h2 class="fw-bold" style="color: #2c3e50;">Kütüphane Duyuru Merkezi</h2>
        <p class="text-muted fs-5">Kütüphanemizle ilgili en güncel haberler, yeni gelen kitaplar ve önemli bilgilendirmeler</p>
        <div class="mx-auto" style="width: 60px; height: 4px; background-color: #0d6efd; border-radius: 2px;"></div>
    </div>

    <div class="row">
        @if (Model == null || Model.Count == 0)
        {
            <div class="col-12 text-center text-muted py-5 card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <i class="far fa-bell-slash fa-4x mb-3 text-secondary opacity-50"></i>
                    <h5 class="fw-bold">Şu Anda Aktif Bir Duyuru Bulunmuyor</h5>
                    <p class="mb-0 small">Yeni duyurular yayınlandığında bu alanda listelenecektir. Lütfen daha sonra tekrar kontrol edin.</p>
                </div>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                // Öğrencilerin gözünü yormayacak hafif soft renkler ve ikonlar
                string accentColor = "#6c757d";
                string categoryIcon = "fas fa-info-circle";
                string badgeClass = "bg-secondary";

                if (item.KATEGORI == "Yeni Kitap")
                {
                    accentColor = "#198754";
                    categoryIcon = "fas fa-book-open";
                    badgeClass = "text-success bg-success-subtle border border-success-subtle";
                }
                else if (item.KATEGORI == "Kitapları Geciktirmeyin")
                {
                    accentColor = "#dc3545";
                    categoryIcon = "fas fa-clock";
                    badgeClass = "text-danger bg-danger-subtle border border-danger-subtle";
                }
                else if (item.KATEGORI == "İletişim")
                {
                    accentColor = "#0dcaf0";
                    categoryIcon = "fas fa-envelope";
                    badgeClass = "text-info bg-info-subtle border border-info-subtle";
                }

                <div class="col-12 mb-4">
                    <div class="card border-0 shadow-sm student-announcement-card" style="border-left: 4px solid @accentColor !important; border-radius: 12px; transition: all 0.2s ease-in-out;">
                        <div class="card-body p-4">

                            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                                <span class="badge @badgeClass rounded-pill px-3 py-2 fw-bold" style="font-size: 12px;">
                                    <i class="@categoryIcon me-1"></i> @item.KATEGORI
                                </span>

                                <span class="text-muted small fw-semibold" style="font-size: 13px;">
                                    <i class="far fa-calendar-alt text-secondary me-1"></i>
                                    @(item.TARIH != null ? Convert.ToDateTime(item.TARIH).ToString("dd MMMM yyyy") : "-")
                                </span>
                            </div>

                            <h4 class="card-title fw-bold mb-3" style="color: #343a40; font-size: 19px;">
                                @item.BASLIK
                            </h4>

                            <p class="card-text text-secondary mb-0" style="font-size: 15px; line-height: 1.6; text-align: justify; white-space: pre-line;">
                                @item.ICERIK
                            </p>

                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .student-announcement-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.06) !important;
        background-color: #ffffff;
    }
    /* Bootstrap alt sürümleriyle uyumluluk için hafif renk sınıfları koruması */
    .bg-success-subtle {
        background-color: #e8f5e9 !important;
    }

    .bg-danger-subtle {
        background-color: #ffebee !important;
    }

    .bg-info-subtle {
        background-color: #e0f7fa !important;
    }
</style>

