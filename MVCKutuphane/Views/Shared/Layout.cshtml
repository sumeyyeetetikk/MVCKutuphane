@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kütüphane Yönetim Paneli</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <style>
        body {
            background: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        .sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            background: #1e293b;
            color: white;
            transition: .3s;
            z-index: 1000;
        }

        .sidebar .logo {
            padding: 25px;
            font-size: 22px;
            font-weight: bold;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }

        .sidebar a {
            color: #cbd5e1;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 13px 25px;
            transition: .3s;
            font-size: 15px;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background: #334155;
            color: #fff;
            border-left: 4px solid #38bdf8;
        }

        .main-content {
            margin-left: 260px;
            transition: .3s;
        }

        .topbar {
            background: #fff;
            padding: 18px 25px;
            box-shadow: 0 4px 20px rgba(0,0,0,.05);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .search-box {
            max-width: 350px;
            width: 100%;
        }

        .content-area {
            padding: 30px;
        }

        .admin-card {
            background: #fff;
            border-radius: 18px;
            padding: 25px;
            box-shadow: 0 8px 25px rgba(0,0,0,.06);
        }

        .sidebar.collapsed {
            width: 80px;
        }

        .sidebar.collapsed span {
            display: none;
        }

        .sidebar.collapsed .logo {
            font-size: 0;
            text-align: center;
        }

        .sidebar.collapsed .logo::after {
            content: "K";
            font-size: 24px;
        }

        .main-content.expanded {
            margin-left: 80px;
        }

        @@media(max-width: 768px) {
            .sidebar {
                left: -260px;
            }

            .sidebar.mobile-active {
                left: 0;
            }

            .main-content {
                margin-left: 0;
            }

            .topbar {
                flex-direction: column;
                gap: 15px;
                align-items: stretch;
            }
        }
    </style>
</head>

<body>

    <div class="sidebar" id="sidebar">
        <div class="logo">
            <i class="fa-solid fa-book-open-reader me-2"></i>
            Kütüphane
        </div>

        <a href="/Istatistik/Index" class="active">
            <i class="fa-solid fa-chart-line"></i>
            <span>Dashboard</span>
        </a>

        <a href="/Kitap/Index">
            <i class="fa-solid fa-book"></i>
            <span>Kitaplar</span>
        </a>

        <a href="/Kategori/Index">
            <i class="fa-solid fa-layer-group"></i>
            <span>Kategoriler</span>
        </a>

        <a href="/Yazar/Index">
            <i class="fa-solid fa-pen-nib"></i>
            <span>Yazarlar</span>
        </a>

        <a href="/Uye/Index">
            <i class="fa-solid fa-users"></i>
            <span>Üyeler</span>
        </a>

        <a href="/Personel/Index">
            <i class="fa-solid fa-user-tie"></i>
            <span>Personeller</span>
        </a>
        @if (User.IsInRole("A"))
        {
            <a href="/Odunc/Index">
                <i class="fa-solid fa-hand-holding-hand"></i>
                <span>Kitap Ödünç İşlemleri</span>
            </a>

        }
        <a href="/Islem/Index">
            <i class="fa-solid fa-hand-holding-hand"></i>
            <span>İşlemler</span>
        </a>

        <a href="/Duyuru/Index">
            <i class="fa-star-of-life fa-sad-tear"></i>
            <span>Duyurular</span>
        </a>
        <a href="/HavaDurumu/Index">
            <i class="fa-solid fa-wallet"></i>
            <span>Hava Durumu</span>
        </a>
        <a href="/Istatistik/Index">
            <i class="fa-solid fa-chart-pie"></i>
            <span>İstatistikler</span>
        </a>

        <a href="/Istatistik/Galeri">
            <i class="fa-solid fa-chart-pie"></i>
            <span>Galeri</span>
        </a>

        <a href="/Istatistik/LinqKart">
            <i class="fa-solid fa-caret-down"></i>
            <span>Linq Kartlar</span>
        </a>

        <a href="/Grafik/Index">
            <i class="fa-solid fa-chart-area"></i>
            <span>Grafikler</span>
        </a>
        <a href="/Ayarlar/Index">
            <i class="fa-solid fa-chart-area"></i>
            <span>Ayarlar</span>
        </a>

        <a href="/Login/Logout">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Çıkış Yap</span>
        </a>
    </div>

    <div class="main-content" id="mainContent">

        <div class="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-outline-dark" id="menuToggle">
                    <i class="fa-solid fa-bars"></i>
                </button>

                <h5 class="mb-0 fw-bold">Kütüphane Yönetim Paneli</h5>
            </div>

            <div class="search-box">
                <input type="text" class="form-control rounded-pill" placeholder="Kitap, üye veya yazar ara...">
            </div>

            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-light position-relative rounded-circle">
                    <i class="fa-solid fa-bell"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                        
                    </span>
                </button>

                <div class="d-flex align-items-center gap-2">
                    <div class="bg-dark text-white rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <div>
                        <div class="fw-bold">Admin</div>
                        <small class="text-muted">Yönetici</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="content-area">
            <div class="admin-card">
                @RenderBody()
            </div>
        </div>

    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const menuToggle = document.getElementById("menuToggle");
        const sidebar = document.getElementById("sidebar");
        const mainContent = document.getElementById("mainContent");

        menuToggle.addEventListener("click", function () {
            if (window.innerWidth <= 768) {
                sidebar.classList.toggle("mobile-active");
            } else {
                sidebar.classList.toggle("collapsed");
                mainContent.classList.toggle("expanded");
            }
        });
    </script>
</body>
</html>