
@model MVCKutuphane.Models.Entity.TBLUYELER
@{
    ViewBag.Title = "UyeGetir";
    Layout = "~/Views/Shared/Layout.cshtml";
}



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="bg-primary text-white p-4">

                    <h3 class="fw-bold mb-1">

                        <i class="fas fa-user-edit me-2"></i>
                        Üye Güncelle

                    </h3>

                    <p class="mb-0 text-light">
                        Üye bilgilerini düzenleyebilirsiniz.
                    </p>

                </div>

                <div class="card-body p-5">

                    @using (Html.BeginForm("UYeGuncelle", "Uye", FormMethod.Post))
                    {

                        @Html.HiddenFor(x => x.ID)

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Ad</label>
                                @Html.TextBoxFor(x => x.AD, new { @class = "form-control rounded-3" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Soyad</label>
                                @Html.TextBoxFor(x => x.SOYAD, new { @class = "form-control rounded-3" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Mail</label>
                                @Html.TextBoxFor(x => x.MAIL, new { @class = "form-control rounded-3" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Telefon</label>
                                @Html.TextBoxFor(x => x.TELEFON, new { @class = "form-control rounded-3" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Kullanıcı Adı</label>
                                @Html.TextBoxFor(x => x.KULLANICIADI, new { @class = "form-control rounded-3" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Şifre</label>
                                @Html.TextBoxFor(x => x.SIFRE, new { @class = "form-control rounded-3" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Fotoğraf Url</label>
                                @Html.TextBoxFor(x => x.FOTOGRAF, new { @class = "form-control rounded-3" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Okul</label>
                                @Html.TextBoxFor(x => x.OKUL, new { @class = "form-control rounded-3" })
                            </div>

                        </div>

                        <div class="mt-4 d-flex gap-2">

                            <button class="btn btn-primary rounded-3 px-4 shadow-sm">

                                <i class="fas fa-save me-2"></i>
                                Güncelle

                            </button>

                            <a href="/Uye/Index/"
                               class="btn btn-outline-secondary rounded-3 px-4">

                                Geri Dön

                            </a>

                        </div>

                    }

                </div>

            </div>

        </div>

    </div>

</div>