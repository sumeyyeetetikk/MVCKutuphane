
@{
    ViewBag.Title = "UyeKitapGecmis";
    Layout = "~/Views/Shared/Layout.cshtml";
}


<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

<div class="container-fluid" style="padding: 25px; font-family: 'Segoe UI', sans-serif;">

    <!-- ÜST BAŞLIK -->
    <div class="d-flex justify-content-between align-items-center mb-4" style="border-bottom: 2px solid #f1f1f1; padding-bottom: 15px;">
        <div>
            <h2 style="color: #2c3e50; margin: 0; font-weight: 600;">
                <i class="fas fa-history text-primary" style="margin-right: 10px;"></i> @ViewBag.UyeAdi Kitap Hareketleri
            </h2>
            <p style="color: #7f8c8d; margin: 5px 0 0 0; font-size: 14px;">Üyenin kütüphanemizden bugüne kadar ödünç aldığı tüm kitapların kronolojik listesi.</p>
        </div>
        <div style="background: #3498db; color: white; padding: 8px 16px; border-radius: 30px; font-weight: bold; font-size: 14px;">
            Toplam Okunan: @Model.Count Kitap
        </div>
    </div>

    <!-- GEÇMİŞ TABLOSU -->
    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle" style="margin: 0; font-size: 14px;">
                    <thead class="table-light" style="color: #34495e; font-weight: 600;">
                        <tr>
                            <th style="padding: 15px;">Kitap Görsel / Adı</th>
                            <th style="padding: 15px;">Yazar</th>
                            <th style="padding: 15px;"><i class="far fa-calendar-alt text-secondary"></i> Alış Tarihi</th>
                            <th style="padding: 15px;"><i class="far fa-calendar-check text-secondary"></i> İade Tarihi</th>
                            <th style="padding: 15px; text-align: center;">Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center" style="padding: 50px; color: #95a5a6;">
                                    <i class="fas fa-book-open fa-3x mb-3" style="color: #bdc3c7;"></i>
                                    <p class="mb-0" style="font-size: 16px;">Henüz kütüphanemizden kitap ödünç almamış.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr style="transition: background 0.2s;">
                                    <!-- Kitap Adı -->
                                    <td style="padding: 15px; font-weight: 600; color: #2c3e50;">
                                        <i class="fas fa-book text-muted me-2"></i> @item.TBLKITAP.AD
                                    </td>

                                    <!-- Yazar -->
                                    <td style="padding: 15px; color: #555;">
                                        @item.TBLKITAP.TBLYAZAR.AD @item.TBLKITAP.TBLYAZAR.SOYAD
                                    </td>

                                    <!-- Alış Tarihi -->
                                    <td style="padding: 15px; color: #7f8c8d;">
                                        @(item.ALISTARIH != null ? Convert.ToDateTime(item.ALISTARIH).ToString("dd MMM yyyy") : "-")
                                    </td>

                                    <!-- İade Tarihi -->
                                    <td style="padding: 15px; color: #7f8c8d;">
                                        @(item.IADETARIH != null ? Convert.ToDateTime(item.IADETARIH).ToString("dd MMM yyyy") : "-")
                                    </td>

                                    <!-- Durum Rozeti -->
                                    <td style="padding: 15px; text-align: center;">
                                        @if (item.ISLEMDURUM == true)
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill" style="font-size: 12px; font-weight: 600;">
                                                <i class="fas fa-hourglass-half me-1"></i> Henüz İade Edilmedi
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill" style="font-size: 12px; font-weight: 600;">
                                                <i class="fas fa-check me-1"></i> Teslim Edildi
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>