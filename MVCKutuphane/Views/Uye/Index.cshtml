
@using PagedList.Mvc
@model PagedList.IPagedList<MVCKutuphane.Models.Entity.TBLUYELER>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/Layout.cshtml";
}




<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

<link href="~/Content/PagedList.css" rel="stylesheet" />

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>
            <h2 class="fw-bold mb-1">Üye Yönetim Paneli</h2>
            <p class="text-muted mb-0">
                Sistemde kayıtlı üyeleri görüntüleyebilir ve yönetebilirsiniz.
            </p>
        </div>

        <a href="/Uye/CreateUye/"
           class="btn btn-dark rounded-3 px-4 shadow-sm">

            <i class="fas fa-user-plus me-2"></i>
            Yeni Üye

        </a>

    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">

                    <tr>
                        <th>#</th>
                        <th>Üye</th>
                        <th>Mail</th>
                        <th>Kullanıcı Adı</th>
                        <th>Telefon</th>
                        <th>Okul</th>
                        <th class="text-center">İşlemler</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td class="fw-semibold text-muted">
                                #@item.ID
                            </td>

                            <td>

                                <div class="d-flex align-items-center gap-3">

                                    <img src="@item.FOTOGRAF"
                                         onerror="this.src='https://i.pravatar.cc/150'"
                                         class="rounded-circle shadow-sm"
                                         style="width:50px;height:50px;object-fit:cover;" />

                                    <div>

                                        <div class="fw-bold">
                                            @item.AD @item.SOYAD
                                        </div>

                                        <small class="text-muted">
                                            Kütüphane Üyesi
                                        </small>

                                    </div>

                                </div>

                            </td>

                            <td>@item.MAIL</td>

                            <td>@item.KULLANICIADI</td>

                            <td>@item.TELEFON</td>

                            <td>@item.OKUL</td>

                            <td>

                                <div class="d-flex justify-content-center gap-2">

                                    <a href="/Uye/UyeGetir/@item.ID"
                                       class="btn btn-outline-primary btn-sm rounded-3 px-3">

                                        <i class="fas fa-pen"></i>

                                    </a>

                                    <a href="/Uye/Sil/@item.ID"
                                       onclick="return confirm('Üye silinsin mi?')"
                                       class="btn btn-outline-danger btn-sm rounded-3 px-3">

                                        <i class="fas fa-trash"></i>

                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <div class="d-flex justify-content-center mt-4">

        @Html.PagedListPager(Model, sayfa => Url.Action("Index", new { sayfa }),
        new PagedListRenderOptions
        {
            LiElementClasses = new List<string> { "page-item" }
        })

    </div>

</div>

<style>

    .pagination li {
        margin: 0 4px;
    }

        .pagination li a,
        .pagination li span {
            border-radius: 10px !important;
            padding: 10px 16px;
            border: none;
            background: #f1f5f9;
            color: #111827;
            font-weight: 600;
        }

    .pagination .active span {
        background: #111827 !important;
        color: white !important;
    }
</style>