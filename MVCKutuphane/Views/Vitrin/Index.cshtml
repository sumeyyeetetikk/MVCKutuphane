@model MVCKutuphane.Models.Sınıflarım.VitrinViewModel
@using PagedList
@using PagedList.Mvc
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<style>
    #aiChatButton {
        position: fixed;
        right: 25px;
        bottom: 25px;
        width: 60px;
        height: 60px;
        border: none;
        border-radius: 50%;
        background: #1abc9c;
        color: white;
        font-size: 28px;
        cursor: pointer;
        z-index: 9999;
        box-shadow: 0 6px 20px rgba(0,0,0,.3);
    }

    .ai-modal-content {
        border-radius: 18px;
        overflow: hidden;
        border: none;
    }

    .ai-modal-header {
        background: #1abc9c;
        color: white;
    }

    .ai-modal-body {
        min-height: 300px;
    }

    .ai-result {
        margin-top: 15px;
        padding: 15px;
        border: 1px solid #1abc9c;
        border-radius: 10px;
        max-height: 350px;
        overflow-y: auto;
        white-space: normal;
    }
</style>
<head>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Freelancer - Start Bootstrap Theme</title>

    <!-- Custom fonts for this theme -->
    <link href="~/web/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,700" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Lato:400,700,400italic,700italic" rel="stylesheet" type="text/css">

    <!-- Theme CSS -->
    <link href="~/web/css/freelancer.min.css" rel="stylesheet">

</head>

<body id="page-top">

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg bg-secondary text-uppercase fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand js-scroll-trigger" href="#page-top">Kütüphanemize Hoş Geldiniz</a>
            <button class="navbar-toggler navbar-toggler-right text-uppercase font-weight-bold bg-primary text-white rounded" type="button" data-toggle="collapse" data-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
                Menu
                <i class="fas fa-bars"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarResponsive">
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item mx-0 mx-lg-1">
                        <a class="nav-link py-3 px-0 px-lg-3 rounded js-scroll-trigger" href="#portfolio">Portfolio</a>
                    </li>
                    <li class="nav-item mx-0 mx-lg-1">
                        <a class="nav-link py-3 px-0 px-lg-3 rounded js-scroll-trigger" href="#about">Hakkımızda</a>
                    </li>
                    <li class="nav-item mx-0 mx-lg-1">
                        <a class="nav-link py-3 px-0 px-lg-3 rounded js-scroll-trigger" href="#contact">İletişim</a>
                    </li>
                    <li class="nav-item mx-0 mx-lg-1">
                        <a class="nav-link py-3 px-0 px-lg-3 rounded js-scroll-trigger" href="/Login/GirisYap">Login</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Masthead -->
    <header class="masthead bg-primary text-white text-center">
        <div class="container d-flex align-items-center flex-column">

            <!-- Masthead Avatar Image -->
            <img class="masthead-avatar mb-5" src="~/web/img/library.png" alt="">

            <!-- Masthead Heading -->
            <h1 class="masthead-heading text-uppercase mb-0">KÜTÜPHANE DÜNYASI</h1>

            <!-- Icon Divider -->
            <div class="divider-custom divider-light">
                <div class="divider-custom-line"></div>
                <div class="divider-custom-icon">
                    <i class="fas fa-star"></i>
                </div>
                <div class="divider-custom-line"></div>
            </div>

            <!-- Masthead Subheading -->
            <p class="masthead-subheading font-weight-light mb-0">Binlerce Kitap • Kolay Ödünç Sistemi</p>

        </div>
    </header>

    <!-- Portfolio Section -->
    <!-- Portfolio Section -->
    <section class="page-section portfolio" id="portfolio">
        <div class="container">

            <h2 class="page-section-heading text-center text-uppercase text-secondary mb-0">
                KITAPLARIMIZ
            </h2>

            <div class="divider-custom">
                <div class="divider-custom-line"></div>
                <div class="divider-custom-icon">
                    <i class="fas fa-star"></i>
                </div>
                <div class="divider-custom-line"></div>
            </div>

            <!-- Kategori Filtreleme -->
            <div class="text-center mb-5">
                <a href="/Vitrin/Index#portfolio" class="btn btn-outline-primary m-1">
                    Tüm Kitaplar
                </a>

                @foreach (var kategori in ViewBag.Kategoriler)
                {
                    <a href="/Vitrin/Index?kategoriId=@kategori.ID#portfolio"
                       class="btn btn-outline-primary m-1">
                        @kategori.AD
                    </a>
                }
            </div>

            <!-- Kitaplar -->
            <div class="row">
                @foreach (var x in Model.Kitaplar)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="portfolio-item mx-auto"
                             data-toggle="modal"
                             data-target="#portfolioModal@(x.ID)">

                            <div class="portfolio-item-caption d-flex align-items-center justify-content-center h-100 w-100">
                                <div class="portfolio-item-caption-content text-center text-white">
                                    <i class="fas fa-plus fa-3x"></i>
                                </div>
                            </div>

                            <img class="img-fluid"
                                 src="@x.KITAPRESIM"
                                 alt="@x.AD"
                                 style="height:620px; width:100%; object-fit:cover; border-radius:12px;">
                        </div>
                    </div>
                }
            </div>

            <!-- Sayfalama -->
            <div class="text-center mt-4">
                @Html.PagedListPager(
                    Model.Kitaplar,
                    sayfa => Url.Action("Index", new
                    {
                        sayfa,
                        kategoriId = ViewBag.SeciliKategori
                    }) + "#portfolio"
                )
            </div>

        </div>
    </section>
    <!-- Contact Section -->
    <section class="page-section" id="contact">
        <div class="container">

            <!-- Contact Section Heading -->
            <h2 class="page-section-heading text-center text-uppercase text-secondary mb-0">Contact Me</h2>

            <!-- Icon Divider -->
            <div class="divider-custom">
                <div class="divider-custom-line"></div>
                <div class="divider-custom-icon">
                    <i class="fas fa-star"></i>
                </div>
                <div class="divider-custom-line"></div>
            </div>

            <!-- Contact Section Form -->
            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <!-- To configure the contact form email address, go to mail/contact_me.php and update the email address in the PHP file on line 19. -->
                    @using (Html.BeginForm("Index", "Vitrin", FormMethod.Post))
                    {
                        <form name="sentMessage" id="contactForm" novalidate="novalidate">
                            <div class="control-group">
                                <div class="form-group floating-label-form-group controls mb-0 pb-2">
                                    <label>Ad Soyad</label>
                                    <input class="form-control" id="name" name="AD" type="text" placeholder="Adınız" required="required" data-validation-required-message="Please enter your name.">
                                    <p class="help-block text-danger"></p>
                                </div>
                            </div>
                            <div class="control-group">
                                <div class="form-group floating-label-form-group controls mb-0 pb-2">
                                    <label>Email Adresi</label>
                                    <input class="form-control" name="MAIL" id="email" type="email" placeholder="Email Adresi" required="required" data-validation-required-message="Please enter your email address.">
                                    <p class="help-block text-danger"></p>
                                </div>
                            </div>
                            <div class="control-group">
                                <div class="form-group floating-label-form-group controls mb-0 pb-2">
                                    <label>Mesaj Konusu</label>
                                    <input class="form-control" id="konu" name="KONU " type="tel" placeholder="Mesaj Başlığı" required="required" data-validation-required-message="Please enter your phone number.">
                                    <p class="help-block text-danger"></p>
                                </div>
                            </div>
                            <div class="control-group">
                                <div class="form-group floating-label-form-group controls mb-0 pb-2">
                                    <label>Mesajınız</label>
                                    <textarea class="form-control" id="message" name="MESAJ" rows="5" placeholder="Mesajınız" required="required" data-validation-required-message="Please enter a message."></textarea>
                                    <p class="help-block text-danger"></p>
                                </div>
                            </div>
                            <br>
                            <div id="success"></div>
                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-xl" id="sendMessageButton">Gönder</button>
                            </div>
                        </form>

                    }
                </div>
            </div>

        </div>
    </section>




    <!-- Footer -->
    <!-- Footer -->
    <footer class="footer text-center">
        <div class="container">
            <div class="row">

                <!-- İletişim -->
                <div class="col-lg-4 mb-5 mb-lg-0">
                    <h4 class="text-uppercase mb-4">İletişim</h4>
                    <p class="lead mb-0">
                        İstanbul, Türkiye
                        <br>
                        kutuphane@ornek.com
                    </p>
                </div>

                <!-- Sosyal Medya -->
                <div class="col-lg-4 mb-5 mb-lg-0">
                    <h4 class="text-uppercase mb-4">Bizi Takip Edin</h4>

                    <a class="btn btn-outline-light btn-social mx-1" href="#">
                        <i class="fab fa-fw fa-facebook-f"></i>
                    </a>

                    <a class="btn btn-outline-light btn-social mx-1" href="#">
                        <i class="fab fa-fw fa-instagram"></i>
                    </a>

                    <a class="btn btn-outline-light btn-social mx-1" href="#">
                        <i class="fab fa-fw fa-linkedin-in"></i>
                    </a>

                    <a class="btn btn-outline-light btn-social mx-1" href="#">
                        <i class="fab fa-fw fa-github"></i>
                    </a>
                </div>

                <!-- Hakkımızda -->
                <div class="col-lg-4">
                    <h4 class="text-uppercase mb-4">Kütüphane Dünyası</h4>
                    <p class="lead mb-0">
                        Kütüphane Dünyası, kitap severleri binlerce eserle buluşturan
                        modern bir kütüphane otomasyon sistemidir. Kitapları
                        keşfedebilir, detaylarını inceleyebilir ve yapay zeka destekli
                        öneriler alabilirsiniz.
                    </p>
                </div>

            </div>
        </div>
    </footer>

    <section class="copyright py-4 text-center text-white">
        <div class="container">
            <small>
                © @DateTime.Now.Year Kütüphane Dünyası | Tüm Hakları Saklıdır.
            </small>
        </div>
    </section>

    <!-- Scroll to Top Button (Only visible on small and extra-small screen sizes) -->
    <div class="scroll-to-top d-lg-none position-fixed ">
        <a class="js-scroll-trigger d-block text-center text-white rounded" href="#page-top">
            <i class="fa fa-chevron-up"></i>
        </a>
    </div>

    <!-- Portfolio Modals -->
    <!-- Portfolio Modal 1 -->
    @foreach (var x in Model.Kitaplar)
    {
        <div class="portfolio-modal modal fade" id="portfolioModal@(x.ID)" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog modal-xl" role="document">
                <div class="modal-content">

                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">
                            <i class="fas fa-times"></i>
                        </span>
                    </button>

                    <div class="modal-body text-center">
                        <div class="container">
                            <div class="row justify-content-center">
                                <div class="col-lg-8">

                                    <h2 class="portfolio-modal-title text-secondary text-uppercase mb-0">
                                        @x.AD
                                    </h2>

                                    <div class="divider-custom">
                                        <div class="divider-custom-line"></div>
                                        <div class="divider-custom-icon">
                                            <i class="fas fa-star"></i>
                                        </div>
                                        <div class="divider-custom-line"></div>
                                    </div>

                                    <img class="img-fluid rounded mb-5"
                                         src="@x.KITAPRESIM"
                                         alt="@x.AD"
                                         style="max-height:500px; object-fit:cover;">

                                    <p>
                                        <strong>Yazar:</strong>
                                        @x.TBLYAZAR.AD @x.TBLYAZAR.SOYAD
                                    </p>

                                    <p>
                                        <strong>Yayınevi:</strong>
                                        @x.YAYIMEVI
                                    </p>

                                    <p>
                                        <strong>Basım Yılı:</strong>
                                        @x.BASIMYIL
                                    </p>

                                    <p class="mb-5">
                                        <strong>Kitap Detayı:</strong><br />
                                        @x.DETAY
                                    </p>

                                    <button class="btn btn-primary" data-dismiss="modal">
                                        <i class="fas fa-times fa-fw"></i>
                                        Kapat
                                    </button>

                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    }


    <!-- Bootstrap core JavaScript -->
    <script src="~/web/vendor/jquery/jquery.min.js"></script>
    <script src="~/web/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- Plugin JavaScript -->
    <script src="~/web/vendor/jquery-easing/jquery.easing.min.js"></script>

    <!-- Contact Form JavaScript -->
    <script src="~/web/js/jqBootstrapValidation.js"></script>
    <script src="~/web/js/contact_me.js"></script>

    <!-- Custom scripts for this template -->
    <script src="~/web/js/freelancer.min.js"></script>


    <script>
        function toggleAiChat() {
            var chatBox = document.getElementById("aiChatBox");

            if (chatBox.style.display === "none" || chatBox.style.display === "") {
                chatBox.style.display = "block";
            } else {
                chatBox.style.display = "none";
            }
        }

        function aiOneriAl() {
            var ruhHali = $("#ruhHali").val();

            if (ruhHali.trim() === "") {
                $("#aiResult").html("Lütfen nasıl hissettiğini yaz 😊");
                return;
            }

            $("#aiResult").html("🤖 Kitap danışmanın düşünüyor...");

            $.ajax({
                url: "/Vitrin/OneriGetir",
                type: "POST",
                data: { ruhHali: ruhHali },
                success: function (response) {
                    if (response.success) {
                        $("#aiResult").html(response.cevap.replace(/\n/g, "<br>"));
                    } else {
                        $("#aiResult").html(response.message);
                    }
                },
                error: function () {
                    $("#aiResult").html("Bir hata oluştu. Lütfen tekrar dene.");
                }
            });
        }
    </script>

    <button id="aiChatButton" data-toggle="modal" data-target="#aiModal">
        🤖
    </button>

    <div class="modal fade" id="aiModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content ai-modal-content">

                <div class="modal-header ai-modal-header">
                    <h5 class="modal-title">AI Kitap Danışmanı</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">
                        <span>&times;</span>
                    </button>
                </div>

                <div class="modal-body ai-modal-body">
                    <p>Bugün nasıl hissediyorsun? Sana uygun kitap önerebilirim 😊</p>

                    <div id="aiResult" class="ai-result">
                        Henüz öneri alınmadı.
                    </div>
                </div>

                <div class="modal-footer">
                    <input type="text" id="ruhHali" class="form-control"
                           placeholder="Örn: Güneşli bir günde sahilde okuyacak kitap...">

                    <button class="btn btn-primary" onclick="aiOneriAl()">
                        Gönder
                    </button>
                </div>

            </div>
        </div>
    </div>

</body>

</html>