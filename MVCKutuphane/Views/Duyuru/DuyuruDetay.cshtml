@model MVCKutuphane.Models.Entity.TBLDUYURULAR
@{
    ViewBag.Title = "DuyuruDetay";
    Layout = "~/Views/Shared/Layout.cshtml";
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<div class="container py-5" style="max-width: 800px; font-family: 'Segoe UI', sans-serif;">

    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a href="/Duyuru/Index/" class="btn btn-outline-secondary rounded-3 px-3 fw-semibold">
            <i class="fas fa-arrow-left me-2"></i> Listeye Geri Dön
        </a>
        <span class="badge bg-dark px-3 py-2">Duyuru No: #@Model.ID</span>
    </div>

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="card-header bg-dark text-white p-3 d-flex align-items-center">
            <i class="fas fa-edit text-warning me-2 fa-lg"></i>
            <h5 class="mb-0 fw-bold">Duyuru Detaylarını Düzenle</h5>
        </div>

        <div class="card-body p-4 bg-light">

            @using (Html.BeginForm("DuyuruGuncelle", "Duyuru", FormMethod.Post))
            {
                @Html.HiddenFor(x => x.ID)

                @Html.HiddenFor(x => x.TARIH)

                <div class="mb-3">
                    <label class="form-label fw-bold text-muted"><i class="fas fa-tags me-1"></i> Duyuru Kategorisi</label>
                    <select name="KATEGORI" class="form-select border-2 fw-semibold text-secondary" required>
                        <option value="Yeni Kitap" @(Model.KATEGORI == "Yeni Kitap" ? "selected" : "")>📢 Yeni Kitap</option>
                        <option value="Kitapları Geciktirmeyin" @(Model.KATEGORI == "Kitapları Geciktirmeyin" ? "selected" : "")>⚠️ Kitapları Geciktirmeyin</option>
                        <option value="İletişim" @(Model.KATEGORI == "İletişim" ? "selected" : "")>📞 İletişim</option>
                        <option value="Diğer" @(Model.KATEGORI == "Diğer" ? "selected" : "")>🌐 Diğer</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-muted"><i class="fas fa-heading me-1"></i> Duyuru Başlığı</label>
                    @Html.TextBoxFor(x => x.BASLIK, new { @class = "form-control border-2 fw-semibold", @placeholder = "Başlık giriniz...", @required = "required" })
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-muted"><i class="fas fa-align-left me-1"></i> Duyuru İçerik Detayı</label>
                    @Html.TextAreaFor(x => x.ICERIK, new { @class = "form-control border-2", @rows = "7", @placeholder = "Duyuru içeriği...", @required = "required" })
                </div>

                <div class="mb-4 text-end text-muted small">
                    <i class="far fa-calendar-alt me-1"></i> İlk Yayınlanma Tarihi:
                    @(Model.TARIH != null ? Convert.ToDateTime(Model.TARIH).ToString("dd.MM.yyyy HH:mm") : "-")
                </div>

                <hr style="border-top: 1px dashed #ccc;" />

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <a href="/Duyuru/DuyuruSil/@Model.ID" class="btn btn-outline-danger px-4 rounded-3" onclick="return confirm('Bu duyuruyu tamamen silmek istediğinize emin misiniz?')">
                        <i class="fas fa-trash-alt me-1"></i> Duyuruyu Sil
                    </a>

                    <button type="submit" class="btn btn-success px-5 rounded-3 fw-bold shadow-sm">
                        <i class="fas fa-save me-1"></i> Değişiklikleri Kaydet
                    </button>
                </div>
            }

        </div>
    </div>
</div>