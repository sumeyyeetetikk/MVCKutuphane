@using MVCKutuphane.Models.Entity
@model List<TBLDUYURULAR>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/Layout.cshtml";
}



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<div class="container py-5" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3" style="border-bottom: 2px solid #f1f1f1; padding-bottom: 15px;">
        <div>
            <h2 class="fw-bold mb-1" style="color: #2c3e50;">
                <i class="fas fa-bullhorn text-dark me-2"></i> Duyuru Yönetim Paneli
            </h2>
            <p class="text-muted mb-0" style="font-size: 14px;">Sistemde yayınlanan tüm genel ve özel duyuruları buradan takip edebilirsiniz.</p>
        </div>
        <a href="/Duyuru/YeniDuyuru/" class="btn btn-dark rounded-3 px-4 shadow-sm fw-semibold">
            <i class="fas fa-plus me-2"></i> Yeni Duyuru Yayınla
        </a>
    </div>

    <div class="row">
        @if (Model == null || Model.Count == 0)
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="fas fa-comment-slash fa-4x mb-3" style="color: #ccc;"></i>
                <h5>Sistemde henüz yayınlanmış bir duyuru bulunmuyor.</h5>
                <p>Yukarıdaki "Yeni Duyuru" butonunu kullanarak ilk duyuruyu ekleyebilirsiniz.</p>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                string borderLeftColor = "#6c757d";
                string categoryIcon = "fas fa-info-circle";
                string badgeClass = "bg-secondary";

                if (item.KATEGORI == "Yeni Kitap")
                {
                    borderLeftColor = "#198754";
                    categoryIcon = "fas fa-book-open";
                    badgeClass = "bg-success";
                }
                else if (item.KATEGORI == "Kitapları Geciktirmeyin")
                {
                    borderLeftColor = "#dc3545";
                    categoryIcon = "fas fa-exclaim-triangle";
                    badgeClass = "bg-danger";
                }
                else if (item.KATEGORI == "İletişim")
                {
                    borderLeftColor = "#0dcaf0";
                    categoryIcon = "fas fa-headset";
                    badgeClass = "bg-info text-dark";
                }

                <div class="col-12 mb-3">
                    <div class="card shadow-sm border-0 announcement-card" style="border-left: 5px solid @borderLeftColor !important; border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                        <div class="card-body p-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center">

                            <div style="flex: 4; padding-right: 20px;">
                                <div class="d-flex align-items-center mb-2 flex-wrap gap-2">
                                    <span class="badge @badgeClass rounded-pill px-3 py-1" style="font-size: 11px; font-weight: 600;">
                                        <i class="@categoryIcon me-1"></i> @item.KATEGORI
                                    </span>
                                    <h5 class="card-title mb-0 ms-md-2" style="font-weight: 700; color: #212529; font-size: 16px;">
                                        @item.BASLIK
                                    </h5>
                                </div>
                                <p class="card-text text-muted mb-0" style="font-size: 14px; line-height: 1.5;">
                                    @item.ICERIK
                                </p>
                            </div>

                            <div class="mt-3 mt-md-0 d-flex flex-row flex-md-column align-items-end justify-content-between justify-content-md-center gap-2" style="flex: 1; min-width: 145px;">
                                <span class="text-muted small font-weight-bold" style="font-size: 12px;">
                                    <i class="far fa-calendar-alt me-1"></i>
                                    @(item.TARIH != null ? Convert.ToDateTime(item.TARIH).ToString("dd MMM yyyy") : "-")
                                </span>

                                <div class="d-flex gap-1 mt-md-1">
                                    <a href="/Duyuru/DuyuruDetay/@item.ID" class="btn btn-sm btn-outline-warning rounded-3" title="Düzenle">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/Duyuru/DuyuruSil/@item.ID" class="btn btn-sm btn-outline-danger rounded-3" onclick="return confirm('Bu duyuruyu kaldırmak istediğinize emin misiniz?')" title="Sil">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .announcement-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.08) !important;
        background-color: #fdfdfd;
    }
</style>