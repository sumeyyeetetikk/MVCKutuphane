
@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Aradığınız Kitap Rafta Yok!</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>
        body {
            /* Arka plana kütüphane temalı estetik bir görsel ve koyu bir overlay ekliyoruz */
            background: linear-gradient(rgba(21, 32, 43, 0.85), rgba(21, 32, 43, 0.85)),
                        url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?q=80&w=1920') no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-hidden;
        }

        /* Glassmorphism (Cam) Efektli Kart Tasarımı */
        .glass-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 24px;
            padding: 50px 40px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            color: #ffffff;
            max-width: 650px;
            width: 100%;
        }

        .error-code {
            font-size: 110px;
            font-weight: 900;
            line-height: 1;
            background: linear-gradient(45deg, #ffca28, #ffa000);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 15px;
            letter-spacing: -2px;
        }

        .book-animation-box {
            position: relative;
            display: inline-block;
            margin-bottom: 25px;
        }

        .flying-book {
            font-size: 90px;
            color: #ffca28;
            animation: floatBook 4s ease-in-out infinite;
        }

        .shadow-effect {
            width: 70px;
            height: 10px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 50%;
            margin: 5px auto 0 auto;
            animation: shrinkShadow 4s ease-in-out infinite;
            filter: blur(2px);
        }

        .btn-custom-primary {
            background: linear-gradient(45deg, #ffca28, #ffa000);
            color: #15202b !important;
            border: none;
            padding: 12px 35px;
            border-radius: 50px;
            font-weight: 700;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(255, 202, 40, 0.3);
        }

        .btn-custom-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(255, 202, 40, 0.5);
        }

        .btn-custom-secondary {
            background: transparent;
            color: #ffffff !important;
            border: 2px solid rgba(255, 255, 255, 0.4);
            padding: 10px 30px;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-custom-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: #ffffff;
            transform: translateY(-2px);
        }

        /* Kitabın Havada Süzülme Animasyonu */
        @@keyframes floatBook {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(3deg); }
            100% { transform: translateY(0px) rotate(0deg); }
        }

        /* Kitap Yükseldikçe Alttaki Gölgenin Küçülmesi */
        @@keyframes shrinkShadow {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(0.6); opacity: 0.4; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center align-items-center">
        <div class="glass-card text-center animate__animated animate__fadeIn">

            <div class="book-animation-box">
                <i class="fas fa-book-open flying-book"></i>
                <div class="shadow-effect"></div>
            </div>

            <div class="error-code">404</div>
            <h2 class="fw-bold mb-3" style="letter-spacing: 0.5px;">Aradığınız Kitap Rafta Bulunamadı!</h2>

            <p class="opacity-75 fs-5 mb-5 mx-auto" style="max-width: 500px; line-height: 1.6;">
                Görünüşe göre kütüphane arşivimizde kayboldunuz veya aradığınız sayfa başka bir rafa taşındı. Aşağıdaki butonları kullanarak güvenli koridorlara geri dönebilirsiniz.
            </p>

            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <button onclick="history.back()" class="btn btn-custom-secondary">
                    <i class="fas fa-arrow-left me-2"></i> Geri Dön
                </button>
                <a href="/Vitrin/Index" class="btn btn-custom-primary">
                    <i class="fas fa-home me-2"></i> Ana Panele Git
                </a>
            </div>

        </div>
    </div>

</body>
</html>