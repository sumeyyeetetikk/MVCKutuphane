
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/Layout.cshtml";
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<div class="container py-5" style="font-family: 'Segoe UI', sans-serif;">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card border-0 shadow-sm p-4 mb-4 rounded-4 bg-white">
                <h6 class="fw-bold mb-3 text-secondary"><i class="fas fa-globe-europe text-primary me-2"></i> Şehir Seçimi</h6>

                @using (Html.BeginForm("Index", "HavaDurumu", FormMethod.Get))
                {
                    <div class="d-flex gap-2">
                        <select name="sehir" class="form-select border-2 fw-semibold text-secondary" style="border-color: #dee2e6;">
                            <option value="Istanbul" @(ViewBag.SecilenSehir == "Istanbul" ? "selected" : "")>İstanbul</option>
                            <option value="Ankara" @(ViewBag.SecilenSehir == "Ankara" ? "selected" : "")>Ankara</option>
                            <option value="Izmir" @(ViewBag.SecilenSehir == "Izmir" ? "selected" : "")>İzmir</option>
                            <option value="Yalova" @(ViewBag.SecilenSehir == "Yalova" ? "selected" : "")>Yalova</option>
                            <option value="Bursa" @(ViewBag.SecilenSehir == "Bursa" ? "selected" : "")>Bursa</option>
                            <option value="Antalya" @(ViewBag.SecilenSehir == "Antalya" ? "selected" : "")>Antalya</option>
                        </select>

                        <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                            Sorgula
                        </button>
                    </div>
                }
            </div>

            <div class="card border-0 shadow-lg text-white rounded-4 overflow-hidden"
                 style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);">

                <div class="card-body p-5 text-center">
                    <h3 class="fw-bold mb-1 text-uppercase"><i class="fas fa-cloud-sun text-warning me-2"></i> @ViewBag.SehirAdi</h3>
                    <p class="text-white-50 small mb-4">Anlık Hava Tahmin Raporu</p>

                    <h1 class="display-1 fw-bold my-3">@ViewBag.Derece°C</h1>

                    <span class="badge bg-white bg-opacity-25 rounded-pill px-4 py-2 text-capitalize fw-semibold mt-2" style="font-size: 14px;">
                        @ViewBag.Durum
                    </span>
                </div>

                <div class="card-footer bg-black bg-opacity-10 border-0 p-3 text-center text-white-50 small">
                    Weather API Entegrasyonu Başarılı
                </div>

            </div>

        </div>
    </div>
</div>

