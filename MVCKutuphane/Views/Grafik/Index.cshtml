
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/Layout.cshtml";
}



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>

<div class="container py-5" style="font-family: 'Segoe UI', sans-serif;">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white p-3 d-flex align-items-center">
                    <i class="fas fa-chart-pie text-warning me-2 fa-lg"></i>
                    <h5 class="mb-0 fw-bold">Yayınevi Kitap Dağılım Oranları</h5>
                </div>

                <div class="card-body bg-white p-4">
                    <p class="text-muted small mb-4">Kütüphane veritabanında kayıtlı kitapların yayınevlerine göre anlık istatistiği grafikte gösterilmektedir.</p>

                    <div id="piechart_div" style="width: 100%; height: 500px;" class="d-flex align-items-center justify-content-center">
                        <div class="text-center text-secondary">
                            <div class="spinner-border text-primary mb-2" role="status"></div>
                            <p class="mb-0 small">Veriler yükleniyor, lütfen bekleyin...</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script type="text/javascript">
    
    google.charts.load('current', { 'packages': ['corechart'] });
    google.charts.setOnLoadCallback(drawChart);

    function drawChart() {
        
        $.ajax({
            type: "GET",
            url: "/Grafik/VisualizeKitapResult/",
            success: function (chartsdata) {

    
                var data = new google.visualization.DataTable();
                data.addColumn('string', 'Yayınevi');
                data.addColumn('number', 'Kitap Sayısı');

                $.each(chartsdata, function (i, row) {
                    data.addRow([row.yayinevi, row.sayi]);
                });

                var options = {
                    title: 'Yayınevi / Toplam Kitap Dağılımı',
                    is3D: true, 
                    pieSliceText: 'value',
                    chartArea: { left: "10%", top: "10%", width: "80%", height: "80%" },
                    fontName: 'Segoe UI',
                    fontSize: 14
                };

                var chart = new google.visualization.PieChart(document.getElementById('piechart_div'));
                chart.draw(data, options);
            },
            error: function () {
                alert("Grafik verileri yüklenirken arka planda bir hata oluştu!");
            }
        });
    }

    $(window).resize(function () {
        drawChart();
    });
</script>