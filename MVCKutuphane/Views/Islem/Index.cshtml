@using MVCKutuphane.Models.Entity
@model List<TBLHAREKET>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/Layout.cshtml";
}



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

<div class="container py-5">

    <!-- HEADER -->

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>

            <h2 class="fw-bold mb-1">

                <i class="fas fa-check-circle text-success me-2"></i>
                Teslim Edilen Kitaplar

            </h2>

            <p class="text-muted mb-0">
                İade işlemi tamamlanan kitap hareketlerini görüntüleyebilirsiniz.
            </p>

        </div>

        <div class="bg-success-subtle text-success fw-semibold px-4 py-2 rounded-pill">

            Toplam:
            @Model.Count Kayıt

        </div>

    </div>

    <!-- TABLE CARD -->

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">

                    <tr>

                        <th>#</th>
                        <th>Kitap</th>
                        <th>Üye</th>
                        <th>Personel</th>
                        <th>Alış Tarihi</th>
                        <th>İade Tarihi</th>
                        <th>Getirdiği Tarih</th>
                        <th class="text-center">Durum</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {

                        <tr>

                            <!-- ID -->

                            <td class="fw-semibold text-muted">
                                #@item.ID
                            </td>

                            <!-- KİTAP -->

                            <td>

                                <div class="d-flex align-items-center gap-3">

                                    <div class="bg-success text-white rounded-circle d-flex justify-content-center align-items-center shadow-sm"
                                         style="width:45px;height:45px;font-weight:700;">

                                        <i class="fas fa-book"></i>

                                    </div>

                                    <div>

                                        <div class="fw-bold">
                                            @item.TBLKITAP.AD
                                        </div>

                                        <small class="text-muted">
                                            Kitap Teslim Edildi
                                        </small>

                                    </div>

                                </div>

                            </td>

                            <!-- ÜYE -->

                            <td>

                                <span class="fw-semibold">
                                    @item.TBLUYELER.AD
                                    @item.TBLUYELER.SOYAD
                                </span>

                            </td>

                            <!-- PERSONEL -->

                            <td>

                                @item.TBLPERSONEL.PERSONEL

                            </td>

                            <!-- ALIŞ TARİHİ -->

                            <td>

                                @Convert.ToDateTime(item.ALISTARIH).ToString("dd.MM.yyyy")

                            </td>

                            <!-- İADE TARİHİ -->

                            <td>

                                @Convert.ToDateTime(item.IADETARIH).ToString("dd.MM.yyyy")

                            </td>

                            <!-- GETİRDİĞİ TARİH -->

                            <td>

                                @Convert.ToDateTime(item.UYEGETIRTARIH).ToString("dd.MM.yyyy")

                            </td>

                            <!-- DURUM -->

                            <td class="text-center">

                                <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm">

                                    <i class="fas fa-check me-1"></i>
                                    Teslim Alındı

                                </span>

                            </td>

                        </tr>

                    }

                </tbody>

            </table>

        </div>

    </div>

</div>