@model MVCKutuphane.Models.Entity.TBLADMIN
@{
    ViewBag.Title = "AdminGüncelle";
    Layout = "~/Views/Shared/Layout.cshtml";
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<div class="container py-5" style="font-family: 'Segoe UI', sans-serif;">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="mb-3">
                <a href="/Ayarlar/Index" class="text-decoration-none text-secondary small fw-semibold">
                    <i class="fas fa-arrow-left me-1"></i> Yönetici Listesine Geri Dön
                </a>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="card-header bg-dark text-white p-3 d-flex align-items-center">
                    <i class="fas fa-user-edit text-warning me-2 fa-lg"></i>
                    <h5 class="mb-0 fw-bold">Yönetici Bilgilerini Düzenle</h5>
                </div>

                @using (Html.BeginForm("AdminGüncelle", "Ayarlar", FormMethod.Post))
                {
                    @Html.HiddenFor(x => x.ID)

                    <div class="card-body p-4 bg-light">
                        <p class="text-muted small mb-4">
                            Seçilen yöneticinin kullanıcı adını, erişim şifresini veya sistemdeki rol yetkisini buradan güncelleyebilirsiniz.
                        </p>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-secondary">Kullanıcı Adı</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-2 border-end-0 text-muted">
                                    <i class="fas fa-user"></i>
                                </span>
                                @Html.TextBoxFor(x => x.Kullanici, new { @class = "form-control border-2 border-start-0 fw-semibold", @placeholder = "Kullanıcı adı girin", @required = "required", @autocomplete = "off" })
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-secondary">Giriş Şifresi</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-2 border-end-0 text-muted">
                                    <i class="fas fa-lock"></i>
                                </span>
                                @Html.TextBoxFor(x => x.Sifre, new { @class = "form-control border-2 border-start-0", @placeholder = "Yeni şifre girin", @required = "required" })
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label small fw-bold text-secondary">Yetki Derecesi</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-2 border-end-0 text-muted">
                                    <i class="fas fa-shield-alt"></i>
                                </span>
                                <select name="Yetki" class="form-select border-2 border-start-0 fw-bold text-secondary" required>
                                    <option value="A" @(Model.Yetki == "A" ? "selected" : "")>🔴 Tam Yetki (Admin - A)</option>
                                    <option value="B" @(Model.Yetki == "B" ? "selected" : "")>🟡 Kısıtlı Yetki (Moderatör - B)</option>
                                </select>
                            </div>
                        </div>

                    </div>

                    <div class="card-footer bg-white border-top-0 p-3 d-flex justify-content-end gap-2">
                        <a href="/Ayarlar/Index" class="btn btn-secondary px-4 rounded-3">İptal</a>
                        <button type="submit" class="btn btn-warning px-4 rounded-3 fw-bold text-dark shadow-sm">
                            <i class="fas fa-save me-1"></i> Değişiklikleri Kaydet
                        </button>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

<style>
    /* Tasarım odaklı odaklanma çizgisi temizliği */
    .form-control:focus, .form-select:focus {
        border-color: #212529 !important;
        box-shadow: none !important;
    }

    .input-group-text {
        border-color: #dee2e6;
    }
</style>