
@using MVCKutuphane.Models.Entity
@model List<TBLADMIN>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<div class="container py-5" style="font-family: 'Segoe UI', sans-serif;">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3" style="border-bottom: 2px solid #f1f1f1; padding-bottom: 15px;">
        <div>
            <h2 class="fw-bold mb-1" style="color: #2c3e50;">
                <i class="fas fa-user-shield text-dark me-2"></i> Sistem Yöneticileri
            </h2>
            <p class="text-muted mb-0" style="font-size: 14px;">Kütüphane otomasyonuna erişim yetkisi olan admin hesaplarını buradan yönetebilirsiniz.</p>
        </div>

        <button type="button" class="btn btn-dark rounded-3 px-4 shadow-sm fw-semibold" data-bs-toggle="modal" data-bs-target="#yeniAdminModal">
            <i class="fas fa-user-plus me-2"></i> Yeni Yetkili Ekle
        </button>
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4" style="width: 100px;">ID</th>
                        <th><i class="fas fa-user me-2 opacity-75"></i>Kullanıcı Adı</th>
                        <th><i class="fas fa-key me-2 opacity-75"></i>Şifre</th>
                        <th style="width: 150px;"><i class="fas fa-tags me-2 opacity-75"></i>Yetki Rolü</th>
                        <th class="text-center" style="width: 180px;"><i class="fas fa-cogs me-2 opacity-75"></i>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || Model.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="fas fa-users-slash fa-3x mb-3 text-secondary opacity-50"></i>
                                <h5>Sistemde kayıtlı admin bulunamadı.</h5>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var admin in Model)
                        {
                            string badgeClass = "bg-secondary";
                            string roleName = "Standart Yetki";

                            if (admin.Yetki == "A" || admin.Yetki == "ADMIN")
                            {
                                badgeClass = "bg-danger text-white";
                                roleName = "Tam Yetki (A)";
                            }
                            else if (admin.Yetki == "B" || admin.Yetki == "MODERATOR")
                            {
                                badgeClass = "bg-warning text-dark";
                                roleName = "Kısıtlı Yetki (B)";
                            }

                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#@admin.ID</td>
                                <td class="fw-semibold text-dark">@admin.Kullanici</td>
                                <td class="text-muted" title="Güvenlik nedeniyle şifre gizlenmiştir.">
                                    <code class="text-secondary bg-light px-2 py-1 rounded">••••••••</code>
                                </td>
                                <td>
                                    <span class="badge @badgeClass rounded-pill px-3 py-2 fw-bold" style="font-size: 11px; letter-spacing: 0.5px;">
                                        @roleName
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                       <a href="/Ayarlar/AdminGüncelle/@admin.ID" class="btn btn-sm btn-outline-warning rounded-3 px-3" title="Yetkileri Düzenle">
                                            <i class="fas fa-user-edit me-1"></i> Düzenle
                                        </a>
                                        <a href="/Ayarlar/AdminSil/@admin.ID" class="btn btn-sm btn-outline-danger rounded-3 px-3"
                                           onclick="return confirm('@admin.Kullanici isimli yöneticinin yetkisini tamamen kaldırmak istediğinize emin misiniz?')" title="Yetkiyi Kaldır">
                                            <i class="fas fa-trash-alt me-1"></i> Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="yeniAdminModal" tabindex="-1" aria-labelledby="yeniAdminModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

            <div class="modal-header bg-dark text-white p-3">
                <h5 class="modal-title fw-bold" id="yeniAdminModalLabel">
                    <i class="fas fa-user-plus text-warning me-2"></i>Yeni Yetkili Tanımla
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>

            @using (Html.BeginForm("YeniAdmin", "Ayarlar", FormMethod.Post))
            {
                <div class="modal-body p-4 bg-light">

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Kullanıcı Adı</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-2 border-end-0 text-muted"><i class="fas fa-user"></i></span>
                            <input type="text" name="Kullanici" class="form-control border-2 border-start-0 fw-semibold" placeholder="Örn: sumeyye.nur" required autocomplete="off" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Giriş Şifresi</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-2 border-end-0 text-muted"><i class="fas fa-lock"></i></span>
                            <input type="password" name="Sifre" class="form-control border-2 border-start-0" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small fw-bold text-secondary">Yetki Derecesi</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-2 border-end-0 text-muted"><i class="fas fa-shield-alt"></i></span>
                            <select name="Yetki" class="form-select border-2 border-start-0 fw-bold text-secondary" required>
                                <option value="" disabled selected hidden>Rol Seçiniz...</option>
                                <option value="A">🔴 Tam Yetki (Admin - A)</option>
                                <option value="B">🟡 Kısıtlı Yetki (Moderatör - B)</option>
                            </select>
                        </div>
                    </div>

                </div>

                <div class="modal-footer bg-white border-top-0 p-3 d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-secondary px-4 rounded-3" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-success px-4 rounded-3 fw-bold shadow-sm">
                        <i class="fas fa-check-circle me-1"></i> Yetkiliyi Kaydet
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<style>
    .table-hover tbody tr:hover {
        background-color: #fcfcfc;
        transition: background-color 0.2s ease-in-out;
    }
    /* Input gruplarının estetik birleşimi için küçük fix */
    .input-group-text {
        border-color: #dee2e6;
    }

    .form-control:focus, .form-select:focus {
        border-color: #212529 !important;
        box-shadow: none !important;
    }
</style>