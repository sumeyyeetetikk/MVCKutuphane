@model MVCKutuphane.Models.Entity.TBLHAREKET
@{
    ViewBag.Title = "OduncIade";
    Layout = "~/Views/Shared/Layout.cshtml";
}



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- HEADER -->

                <div class="bg-success text-white p-4">

                    <h3 class="fw-bold mb-1">

                        <i class="fas fa-undo-alt me-2"></i>
                        Kitap İade İşlemi

                    </h3>

                    <p class="mb-0 text-light">
                        Teslim alınan kitabın iade işlemini tamamlayın.
                    </p>

                </div>

                <!-- BODY -->

                <div class="card-body p-5">

                    @using (Html.BeginForm("OduncIade", "Odunc", FormMethod.Post))
                    {

                        @Html.HiddenFor(x => x.ID)

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Kitap
                            </label>

                            <input type="text"
                                   class="form-control form-control-lg rounded-3"
                                   value="@Model.TBLKITAP.AD"
                                   readonly />

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Üye
                            </label>

                            <input type="text"
                                   class="form-control form-control-lg rounded-3"
                                   value="@Model.TBLUYELER.AD @Model.TBLUYELER.SOYAD"
                                   readonly />

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Personel
                            </label>

                            <input type="text"
                                   class="form-control form-control-lg rounded-3"
                                   value="@Model.TBLPERSONEL.PERSONEL"
                                   readonly />

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-4">

                                <label class="form-label fw-semibold">
                                    Alış Tarihi
                                </label>

                                <input type="text"
                                       class="form-control form-control-lg rounded-3"
                                       value="@Convert.ToDateTime(Model.ALISTARIH).ToString("dd.MM.yyyy")"
                                       readonly />

                            </div>

                            <div class="col-md-6 mb-4">

                                <label class="form-label fw-semibold">
                                    İade Tarihi
                                </label>

                                @Html.TextBoxFor(x => x.IADETARIH,
                                "{0:yyyy-MM-dd}",
                                new
                                {
                                    @class = "form-control form-control-lg rounded-3",
                                    type = "date"
                                })

                            </div>
                            <label>Üyenin Getirdiği Tarih</label>
                            @Html.TextBoxFor(x => x.UYEGETIRTARIH, "{0:yyyy-MM-dd}", new
                            {
                                @class = "form-control",
                                type = "date",
                                Value = DateTime.Now.ToString("yyyy-MM-dd")
                            })
                            <br />
                            <label>Geç Gelen Gün Sayısı</label> 
                            <input type="text" class="form-control" id="Gecinput" value="@ViewBag.dgr" />
                            
                        </div>

                        <div class="d-flex gap-2 mt-4">

                            <button class="btn btn-success rounded-3 px-4 py-2 shadow-sm">

                                <i class="fas fa-check-circle me-2"></i>
                               Ödünç Kitabı Geri Al

                            </button>

                            <a href="/Odunc/Index/"
                               class="btn btn-outline-secondary rounded-3 px-4 py-2">

                                Geri Dön

                            </a>

                        </div>

                    }

                </div>

            </div>

        </div>

    </div>

</div>