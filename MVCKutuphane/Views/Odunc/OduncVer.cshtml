@model MVCKutuphane.Models.Entity.TBLHAREKET
@{
    ViewBag.Title = "OduncVer";
    Layout = "~/Views/Shared/Layout.cshtml";
}




<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="bg-dark text-white p-4">

                    <h3 class="fw-bold mb-1">

                        <i class="fas fa-book-open me-2"></i>
                        Kitap Ödünç Ver

                    </h3>

                    <p class="mb-0 text-light">
                        Üyeye kitap teslim işlemini gerçekleştirin.
                    </p>

                </div>

                <div class="card-body p-5">

                    @using (Html.BeginForm("OduncVer", "Odunc", FormMethod.Post))
                    {

                        @*<div class="mb-4">

                            <label class="form-label fw-semibold">
                                Kitap ID
                            </label>

                            @Html.TextBoxFor(x => x.KITAP,
                            new
                            {
                                @class = "form-control form-control-lg rounded-3",
                                placeholder = "Kitap ID giriniz"w
                            })

                        </div>*@

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Üye ID
                            </label>

                            @Html.DropDownListFor(x => x.TBLUYELER.ID, (List<SelectListItem>)ViewBag.dgr1, new { @class = "form-control" })

                            <br />
                           

                            @Html.DropDownListFor(x => x.TBLKITAP.ID, (List<SelectListItem>)ViewBag.dgr2, new { @class = "form-control" })
                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Personel ID
                            </label>

                            @Html.DropDownListFor(x => x.TBLPERSONEL.ID, (List<SelectListItem>)ViewBag.dgr3, new { @class = "form-control" })

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Alış Tarihi
                            </label>

                            @Html.TextBoxFor(x => x.ALISTARIH,
                            "{0:yyyy-MM-dd}",
                            new
                            {
                                @class = "form-control form-control-lg rounded-3",
                                type = "date"
                            })

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                İade Tarihi
                            </label>

                            @Html.TextBoxFor(x => x.IADETARIH,
                            "{0:yyyy-MM-dd}",
                            new
                            {
                                @class = "form-control form-control-lg rounded-3",
                                type = "date"
                            })

                        </div>

                        <div class="d-flex gap-2 mt-4">

                            <button class="btn btn-dark rounded-3 px-4 py-2 shadow-sm">

                                <i class="fas fa-save me-2"></i>
                                Ödünç Ver

                            </button>
                            <input type="hidden" value="False" name="ISLEMDURUM"
                            <a href="/Odunc/Index/"
                               class="btn btn-outline-secondary rounded-3 px-4 py-2">

                                Geri Dön

                            </a>

                        </div>

                    }

                </div>

            </div>

        </div>

    </div>

</div>