@model List<MVCKutuphane.Models.Entity.TBLHAREKET>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/Layout.cshtml";
}



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>

            <h2 class="fw-bold mb-1">
                Ödünç Kitap Hareketleri
            </h2>

            <p class="text-muted mb-0">
                Şuanda ödünçte bulunan kitapları görüntülüyorsunuz.
            </p>

        </div>

        <a href="/Odunc/OduncVer/"
           class="btn btn-dark rounded-3 px-4 shadow-sm">

            <i class="fas fa-book me-2"></i>
            Yeni Ödünç Ver

        </a>

    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">

                    <tr>

                        <th>#</th>
                        <th>Kitap</th>
                        <th>Üye</th>
                        <th>Personel</th>
                        <th>Alış Tarihi</th>
                        <th>İade Tarihi</th>
                        <th class="text-center">İade Al</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {

                        <tr>

                            <td class="fw-semibold text-muted">
                                #@item.ID
                            </td>

                            <td>
                                <span class="fw-semibold">
                                    @item.TBLKITAP.AD
                                </span>
                            </td>

                            <td>
                                @item.TBLUYELER.AD
                                @item.TBLUYELER.SOYAD
                            </td>

                            <td>
                                @item.TBLPERSONEL.PERSONEL
                            </td>

                            <td>
                                @Convert.ToDateTime(item.ALISTARIH).ToString("dd.MM.yyyy")
                            </td>

                            <td>
                                @Convert.ToDateTime(item.IADETARIH).ToString("dd.MM.yyyy")
                            </td>

                            <td class="text-center">

                                <a href="/Odunc/OduncIade/@item.ID"
                                   class="btn btn-success btn-sm rounded-pill px-3 shadow-sm">

                                    <i class="fas fa-undo-alt me-1"></i>
                                    İade Al

                                </a>

                            </td>

                        </tr>

                    }

                </tbody>

            </table>

        </div>

    </div>

</div>