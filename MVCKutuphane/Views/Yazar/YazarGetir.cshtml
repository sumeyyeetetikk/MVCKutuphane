@model MVCKutuphane.Models.Entity.TBLYAZAR
@{
    ViewBag.Title = "YazarGetir";
    Layout = "~/Views/Shared/Layout.cshtml";
}



<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Yazar Güncelle</h3>
            <p class="text-muted mb-0">
                Yazar bilgilerini düzenleyebilirsiniz.
            </p>
        </div>

        <a href="/Yazar/Index" class="btn btn-secondary rounded-pill px-4">
            <i class="fa-solid fa-arrow-left me-2"></i>
            Listeye Dön
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-header bg-white border-0 py-3 rounded-top-4">
            <h5 class="mb-0 fw-bold">
                <i class="fa-solid fa-user-pen text-warning me-2"></i>
                Yazar Düzenleme Paneli
            </h5>
        </div>

        <div class="card-body p-4">

            @using (Html.BeginForm("YazarGuncelle", "Yazar", FormMethod.Post))
            {

                @Html.HiddenFor(x => x.ID)

                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Yazar ID
                    </label>

                    @Html.TextBoxFor(x => x.ID, new
                    {
                        @class = "form-control form-control-lg rounded-4",
                        @readonly = "readonly"
                    })
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Yazar Adı
                    </label>

                    @Html.TextBoxFor(x => x.AD, new
                    {
                        @class = "form-control form-control-lg rounded-4",
                        placeholder = "Yazar adı giriniz..."
                    })
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Yazar Soyadı
                    </label>

                    @Html.TextBoxFor(x => x.SOYAD, new
                    {
                        @class = "form-control form-control-lg rounded-4",
                        placeholder = "Yazar soyadı giriniz..."
                    })
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Detay
                    </label>

                    @Html.TextAreaFor(x => x.Detay, new
                    {
                        @class = "form-control rounded-4",
                        rows = "5",
                        placeholder = "Yazar hakkında açıklama giriniz..."
                    })
                </div>

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn btn-warning rounded-pill px-4">

                        <i class="fa-solid fa-floppy-disk me-2"></i>
                        Güncelle
                    </button>

                    <a href="/Yazar/Index"
                       class="btn btn-outline-secondary rounded-pill px-4">

                        <i class="fa-solid fa-xmark me-2"></i>
                        İptal
                    </a>

                </div>
            }

        </div>
    </div>

</div>