@model MVCKutuphane.Models.Entity.TBLYAZAR
@{
    ViewBag.Title = "YazarEkle";
    Layout = "~/Views/Shared/Layout.cshtml";
}

<div class="container-fluid">

    <div class="mb-4">
        <h3 class="fw-bold mb-1">Yeni Yazar Ekle</h3>
        <p class="text-muted">Kütüphane sistemine yeni yazar ekleyebilirsiniz.</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            @using (Html.BeginForm("YazarEkle", "Yazar", FormMethod.Post))
            {
                <div class="mb-4">
                    <label class="form-label fw-semibold">Yazar Adı</label>
                    @Html.TextBoxFor(x => x.AD, new
                    {
                        @class = "form-control form-control-lg rounded-4",
                        placeholder = "Yazar adını giriniz..."
                    })
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Yazar Soyadı</label>
                    @Html.TextBoxFor(x => x.SOYAD, new
                    {
                        @class = "form-control form-control-lg rounded-4",
                        placeholder = "Yazar soyadını giriniz..."
                    })
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Detay</label>
                    @Html.TextAreaFor(x => x.Detay, new
                    {
                        @class = "form-control rounded-4",
                        rows = "5",
                        placeholder = "Yazar hakkında kısa açıklama giriniz..."
                    })
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="fa-solid fa-floppy-disk me-2"></i>
                        Kaydet
                    </button>

                    <a href="/Yazar/Index" class="btn btn-secondary rounded-pill px-4">
                        <i class="fa-solid fa-arrow-left me-2"></i>
                        Geri Dön
                    </a>
                </div>
            }

        </div>
    </div>

</div>